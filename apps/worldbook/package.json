{
  "name": "@skopunarverk/worldbook-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/finalize-dist.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "test": "astro check && node --test tests/*.test.mjs",
