    "cloudflare:check": "pnpm run build && wrangler deploy --dry-run --config wrangler.jsonc"
  },
  "dependencies": {
    "@skopunarverk/brand": "workspace:*",
    "@skopunarverk/docs": "workspace:*",
    "@skopunarverk/ui": "workspace:*",
    "astro": "6.4.6"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "5.9.3"
  }
}
