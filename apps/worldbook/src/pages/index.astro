---
import BaseLayout from "../layouts/BaseLayout.astro";
import publication from "../generated/publication-index.json";

const volumeStatus: Record<string, string> = { "in-progress": "持续编写", planned: "规划中" };
---
<BaseLayout>
  <section class="page cover">
    <div class="cover-copy"><div><p class="kicker">A living compendium · {publication.volumes.length} volumes</p><h1>为一个世界写下它的<em>自然与文明</em></h1></div><div class="cover-intro"><p>{publication.summary}</p><a class="link-arrow" href="/worldbook/volumes/">打开四卷目录 <span>→</span></a></div></div>
    <div class="cover-map" role="img" aria-label="抽象世界地图"><div class="cover-lines"></div></div>
  </section>
  <section class="page volumes">
    <div class="section-head"><div><p class="kicker">The collection</p><h2>共 {publication.volumes.length} 卷世界书</h2></div><p>{publication.tagline}</p></div>
    <div class="volume-grid">
      {publication.volumes.map((volume) => {
        const publishedChapter = volume.chapters.find((chapter) => chapter.status === "published" && chapter.webPath);
        const href = publishedChapter?.webPath ?? `/worldbook/volumes/#volume-${volume.number}`;
        return <a class="volume-card" href={href} data-status={volume.status}>
          <div class="volume-meta"><span class="roman">{String(volume.number).padStart(2, "0")}</span><span class="content-status">{volumeStatus[volume.status]}</span></div>
          <div><small>{volume.englishTitle}</small><h3>{volume.title}</h3><p>{volume.summary}</p></div>
        </a>;
      })}
    </div>
  </section>
</BaseLayout>
