---
import BaseLayout from "../../layouts/BaseLayout.astro";
import publication from "../../generated/publication-index.json";

const volumeStatus: Record<string, string> = { "in-progress": "持续编写", planned: "规划中" };
const chapterStatus: Record<string, string> = { published: "可在线阅读", stub: "内容骨架", planned: "规划中" };
---
<BaseLayout title={`卷册目录 — ${publication.title}`} description={publication.summary}>
  <div class="page reader"><aside class="folio-nav"><strong>卷册目录</strong>{publication.volumes.map((volume) => <a href={`#volume-${volume.number}`}>{String(volume.number).padStart(2, "0")} · {volume.title}</a>)}</aside>
    <article class="prose"><p class="kicker">Contents · {publication.volumes.length} volumes</p><h1>{publication.tagline}</h1><p>{publication.summary}</p>
      {publication.volumes.map((volume) => <section class="volume-section" data-status={volume.status}>
        <div class="volume-heading"><h2 id={`volume-${volume.number}`}>第 {volume.number} 卷 · {volume.title}</h2><span class="content-status">{volumeStatus[volume.status]}</span></div>
        <p>{volume.summary}</p>
        <div class="chapter-list">{volume.chapters.map((chapter) => <article data-status={chapter.status}>
          <small>{chapterStatus[chapter.status]}</small>
          <b>第 {chapter.number} 章 · {chapter.title}</b>
          <span>{chapter.summary}</span>
          {chapter.status === "published" && chapter.webPath ? <a class="chapter-link" href={chapter.webPath}>阅读本章 →</a> : null}
        </article>)}</div>
      </section>)}
    </article>
  </div>
</BaseLayout>
