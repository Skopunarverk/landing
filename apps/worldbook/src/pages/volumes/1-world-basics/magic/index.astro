---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import RenderedTypst from "@skopunarverk/docs/astro/RenderedTypst.astro";
import content from "../../../../generated/authoritative-content.json";
import publication from "../../../../generated/publication-index.json";

const volume = publication.volumes.find((candidate) => candidate.chapters.some((chapter) => chapter.entry === content.source.path));
const chapter = volume?.chapters.find((candidate) => candidate.entry === content.source.path);
if (!volume || !chapter) throw new Error(`Publication index does not describe ${content.source.path}`);
const pdfFile = volume.entry.split("/").at(-1)?.replace(/\.typ$/, ".pdf");
---
<BaseLayout title={`${chapter.title} — ${publication.title}`} description={chapter.summary}>
  <div class="page reader"><aside class="folio-nav"><strong>{volume.number} · {volume.title}</strong><p>本章由固定 TheWorldBook 提交中的权威 Typst 源生成。</p>{pdfFile ? <a href={`/worldbook/downloads/${pdfFile}`}>下载同源本卷 PDF</a> : null}<a href="/worldbook/volumes/">返回四卷目录</a></aside>
    <article class="prose"><p class="kicker">Volume {volume.number} · Chapter {chapter.number} · {content.source.commit.slice(0, 12)}</p>
      <h1 class="sk-visually-hidden">第{volume.number}卷 · {chapter.title}</h1>
      <style is:global set:html={content.style}></style>
      <RenderedTypst variant="article" lang="zh-CN">
        <Fragment set:html={content.body} />
      </RenderedTypst>
    </article>
  </div>
</BaseLayout>
