---
import BaseLayout from "../layouts/BaseLayout.astro";
import publication from "../generated/publication-index.json";

const downloads = publication.volumes.map((volume) => ({
  ...volume,
  file: volume.entry.split("/").at(-1)?.replace(/\.typ$/, ".pdf") ?? "",
}));
---
<BaseLayout title={`PDF 版本 — ${publication.title}`}><div class="page reader"><aside class="folio-nav"><strong>Portable editions</strong><a href="#volumes">{publication.volumes.length} 卷 PDF</a><a href="#provenance">出版来源</a></aside><article class="prose"><p class="kicker">Typeset editions</p><h1>PDF 版本</h1><p>所有 PDF 均从固定 TheWorldBook 提交中的权威 Typst 入口生成，与网页目录共享同一出版索引。</p><div class="download-list" id="volumes">{downloads.map((volume) => <div class="download-item"><div><strong>{String(volume.number).padStart(2, "0")} · {volume.title}</strong><small>{volume.englishTitle}</small></div><a class="button" href={`/worldbook/downloads/${volume.file}`}>下载 PDF</a></div>)}</div><h2 id="provenance">出版来源</h2><p>当前发布固定到 <code>{publication.source.commit}</code>；目录元数据来自 <code>{publication.source.path}</code>（{publication.source.mode}）。完整文件校验见 <a href="/worldbook/publication-manifest.json">publication manifest</a>。</p></article></div></BaseLayout>
